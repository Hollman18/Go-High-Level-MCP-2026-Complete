{
  "name": "go-high-level-mcp-server",
  "version": "1.0.0",
  "description": "GoHighLevel MCP Server v2.3 - 100% official GHL API coverage, 848 tools, Email V2 live-docs coverage, stability-tiered profiles, API source lock, Codex-ready MCP config",
  "main": "dist/main.js",
  "bin": {
    "ghl-mcp-server": "dist/server.js",
    "ghl-mcp": "scripts/ghl-mcp.mjs"
  },
  "files": [
    "dist/",
    "scripts/",
    "docs/",
    "examples/",
    "mcp-apps/",
    "README.md",
    "QUICKSTART.md",
    "AGENT_SETUP.md",
    "UPDATE_LOG.md",
    "Dockerfile",
    "docker-compose.yml",
    "package.json",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:server": "node scripts/build-server.mjs",
    "build": "npm run build:server",
    "dev": "nodemon --exec ts-node src/main.ts",
    "start": "node dist/main.js",
    "start:stdio": "node dist/server.js",
    "start:http": "node dist/main.js",
    "start:legacy": "node dist/http-server.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "node scripts/build-server.mjs --check",
    "scan:ghl-api": "node scripts/scan-ghl-api-coverage.mjs --refresh && node scripts/generate-official-spec-tools.mjs && node scripts/scan-ghl-api-coverage.mjs && node scripts/classify-local-endpoints.mjs && node scripts/validate-api-source-lock.mjs && npm run build && node scripts/ghl-mcp.mjs report",
    "validate:api-lock": "node scripts/validate-api-source-lock.mjs",
    "ci:ghl-api-drift": "npm run scan:ghl-api && git diff -- docs/GHL-API-COVERAGE-REPORT.md docs/GHL-LOCAL-ENDPOINT-CLASSIFICATION.md docs/api-sources.lock.json docs/ghl-api-coverage.json docs/API-DASHBOARD.md docs/tool-inventory.json src/tools/official-spec-tools.ts src/tools/official-spec-endpoints.json && test -z \"$(git status --porcelain -- docs/GHL-API-COVERAGE-REPORT.md docs/GHL-LOCAL-ENDPOINT-CLASSIFICATION.md docs/api-sources.lock.json docs/ghl-api-coverage.json docs/API-DASHBOARD.md docs/tool-inventory.json src/tools/official-spec-tools.ts src/tools/official-spec-endpoints.json)\"",
    "smoke:ghl-live": "node scripts/ghl-live-smoke.mjs",
    "setup": "node scripts/ghl-mcp.mjs setup",
    "doctor": "node scripts/ghl-mcp.mjs doctor",
    "auth-check": "node scripts/ghl-mcp.mjs auth-check",
    "agent:setup": "node scripts/ghl-mcp.mjs setup --ci --fix",
    "agent:check": "node scripts/ghl-mcp.mjs agent-check",
    "configure:codex": "node scripts/ghl-mcp.mjs configure codex --profile curated",
    "configure:claude": "node scripts/ghl-mcp.mjs configure claude --profile curated",
    "configure:cursor": "node scripts/ghl-mcp.mjs configure cursor --profile curated",
    "configure:windsurf": "node scripts/ghl-mcp.mjs configure windsurf --profile curated",
    "tools:doctor": "node scripts/ghl-mcp.mjs doctor",
    "tools:list": "node scripts/ghl-mcp.mjs list-tools",
    "tools:report": "node scripts/ghl-mcp.mjs report",
    "tools:explorer": "node scripts/ghl-mcp.mjs explorer",
    "tools:configure": "node scripts/ghl-mcp.mjs configure codex",
    "tools:update-api": "node scripts/ghl-mcp.mjs update-api",
    "clean": "rm -rf dist mcp-apps/dist coverage",
    "reset-local": "npm run clean && npm run build",
    "apps:install": "npm install --prefix mcp-apps",
    "apps:setup": "npm run apps:install && npm run apps:build",
    "apps:build": "npm run build --prefix mcp-apps",
    "apps:dev": "npm run dev --prefix mcp-apps",
    "apps:preview": "npm run start:http --prefix mcp-apps",
    "apps:typecheck": "npm run typecheck --prefix mcp-apps",
    "apps:start:stdio": "npm run start:stdio --prefix mcp-apps",
    "apps:start:http": "npm run start:http --prefix mcp-apps"
  },
  "keywords": [
    "mcp",
    "gohighlevel",
    "chatgpt",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  }
}
