# Required: HighLevel private integration token or OAuth access token.
GHL_API_KEY=your_private_integration_api_key_here

# Required: HighLevel sub-account Location ID.
GHL_LOCATION_ID=your_location_id_here

# Optional: HighLevel API base URL.
GHL_BASE_URL=https://services.leadconnectorhq.com

# Optional: HighLevel API Version header, not the project year.
# Do not change this to 2026 unless HighLevel publishes a new required API version.
GHL_API_VERSION=2023-02-21

# Optional: default HTTP/SSE server port.
MCP_SERVER_PORT=8000
NODE_ENV=development

# Optional: only needed for future AI-assisted features.
OPENAI_API_KEY=your_openai_key_here_optional
