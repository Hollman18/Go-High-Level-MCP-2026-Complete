# Required: HighLevel private integration token or OAuth access token.
GHL_API_KEY=your_private_integration_api_key_here

# Required: HighLevel sub-account Location ID.
GHL_LOCATION_ID=your_location_id_here

# Optional: HighLevel API base URL.
GHL_BASE_URL=https://services.leadconnectorhq.com

# Optional: HighLevel API Version header, not the project year.
# Do not change this to 2026 unless HighLevel publishes a new required API version.
GHL_API_VERSION=2023-02-21

# Optional: default HTTP/SSE server port.
MCP_SERVER_PORT=8000
NODE_ENV=development

# Optional but strongly recommended for hosted HTTP/SSE deployments.
# When set, /mcp, /sse, /tools, /execute, and /tools/call require:
# Authorization: Bearer your_strong_remote_mcp_token
MCP_AUTH_TOKEN=your_strong_remote_mcp_token_here

# Optional: public multi-user mode. Users authorize with their own GHL token.
# Set this instead of using a shared global GHL_API_KEY for everyone.
# MCP_AUTH_MODE=byo-ghl-oauth
# MCP_PUBLIC_BASE_URL=https://go.mcpgohighlevel.com
# MCP_OAUTH_SECRET=your_long_random_oauth_encryption_secret

# Optional: CORS mode for hosted HTTP deployments.
# agent: allows HTTPS agent origins plus localhost. Recommended for public MCP connectors.
# strict: only allows localhost, MCP_PUBLIC_BASE_URL, defaults below, and MCP_ALLOWED_ORIGINS.
MCP_CORS_MODE=agent

# Optional: comma-separated browser origins allowed in addition to defaults.
# Server-to-server MCP clients normally do not send Origin and are not affected.
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://platform.openai.com

# Optional: request body limits for hosted HTTP deployments.
MCP_JSON_LIMIT=1mb
MCP_FORM_LIMIT=256kb

# Optional: only needed for future AI-assisted features.
OPENAI_API_KEY=your_openai_key_here_optional
